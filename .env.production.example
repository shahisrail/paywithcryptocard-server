XMR_ADDRESS=44AFFq5kSiGBoZ4NMDwYtN187rua5UdjnU8oYfYaUCSt5MVNVq2zSRf7FHBVPL7pKGFHLyKAhA8tQEyEYbkGiqz

# Frontend URL - Your deployed frontend URL
